   "source": [
    "def is_palindrome(n):\n",
    "    original = n\n",
    "    rev=0\n",
    "    while n>0 :\n",
    "        digit =n%10\n",
    "        rev=rev*10+digit\n",
    "        n=n//10\n",
    "    return original==rev\n",
    "print(is_palindrome(121))\n",
    "print(is_palindrome(123))    "
   ]
  },
