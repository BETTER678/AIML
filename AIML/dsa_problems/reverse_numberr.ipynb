   "source": [
    "Reverse a number \n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "65aac9e3",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "321\n"
     ]
    }
   ],
   "source": [
    "def reverseNumber(num):\n",
    "    rev=0\n",
    "    while num>0:\n",
    "        \n",
    "        rem = num%10\n",
    "        rev= rev*10+rem\n",
    "        num=num//10\n",
    "    return rev\n",
    "     \n",
    "\n",
    "\n",
    "print(reverseNumber(123))\n",
    "\n",
    "\n"
   ]
  }
 ],
