    "def fibonacci(n):\n",
    "    if n<=1:\n",
    "        return n\n",
    "    a,b=0,1\n",
    "    for i in range(2,n+1):\n",
    "        c=a+b\n",
    "        a=b\n",
    "        b=c\n",
    "        print(c)\n",
    "print(fibonacci(10))"
   ]
